# Copy to `.env` for local development. On Render, set these in the service Environment tab.

# Render sets PORT automatically; Next.js uses it in production. Do not set manually on Render.
# PORT=3000

# PostgreSQL (Render: use Internal Database URL for the web service; External URL for local dev)
DATABASE_URL="postgresql://pgc_jobs_platform_db_user:qEKLJHTnUZvnjBLMRqeaZ9R0lyXaYE6U@dpg-d79r2e7fte5s739rlkr0-a/pgc_jobs_platform_db"

# NextAuth — required in production
NEXTAUTH_SECRET="eBeGoApw9Fo76w4MM7HBa7m0bFV/UgRwTNzXSPFYXJI="
# Public URL of the app (no trailing slash). Examples:
# Local: http://localhost:3000
# Render: https://your-service-name.onrender.com
NEXTAUTH_URL="https://lib-staffconnect.vercel.app/"

# Recommended on Render (reverse proxy). Optional locally.
NEXTAUTH_TRUST_HOST="true"

# Optional: Frontend-only deployment on Vercel with backend already on Render.
# When BACKEND_URL is set, Next.js rewrites /api/* and /uploads/* to this backend.
# Example:
# BACKEND_URL="https://your-render-backend.onrender.com"
BACKEND_URL="postgresql://pgc_jobs_platform_db_user:qEKLJHTnUZvnjBLMRqeaZ9R0lyXaYE6U@dpg-d79r2e7fte5s739rlkr0-a.oregon-postgres.render.com/pgc_jobs_platform_db"

