# Copy to `.env` for local development.
# For production, use dedicated templates:
# - `.env.render.example` for Render backend
# - `.env.vercel.example` for Vercel frontend

# Render sets PORT automatically; Next.js uses it in production. Do not set manually on Render.
# PORT=3000

# =========================
# Backend (Render) variables
# =========================
# PostgreSQL connection used by backend API service.
# Render backend should use its INTERNAL database URL.
# Local development can use an external URL.
DATABASE_URL="https://pgc-jobs-platform.onrender.com"

# NextAuth (backend auth config)
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="eBeGoApw9Fo76w4MM7HBa7m0bFV/UgRwTNzXSPFYXJI="
# Public URL of the app (no trailing slash). Examples:
# Local: http://localhost:3000
# Render backend URL when backend hosts auth endpoints, e.g.:
# https://your-backend.onrender.com
NEXTAUTH_URL="https://pgc-jobs-platform.onrender.com"

# Recommended on Render (reverse proxy). Optional locally.
NEXTAUTH_TRUST_HOST="true"

# =========================
# Frontend (Vercel) variables
# =========================
# Required for frontend-only deployment on Vercel with backend on Render.
# Must be an HTTP/HTTPS backend URL (NOT a postgres:// URL).
# Example:
# BACKEND_URL="https://your-backend.onrender.com"
BACKEND_URL="https://pgc-jobs-platform.onrender.com"

# Frontend public URL (set this on Vercel):
# NEXTAUTH_URL="https://your-frontend.vercel.app"

# Optional — first deploy / create-admin script
# ADMIN_EMAIL="admin@example.com"
# ADMIN_PASSWORD="change-me"

# Optional OAuth login (Google)
# Set these on the backend service where NextAuth runs.
# GOOGLE_CLIENT_ID="your-google-client-id"
# GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Optional password reset config (minutes before reset token expires)
# PASSWORD_RESET_TTL_MINUTES="30"

# Optional SMTP mail delivery for password reset emails
# SMTP_HOST="smtp.your-provider.com"
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER="smtp-username"
# SMTP_PASS="smtp-password"
# SMTP_FROM="Lib-StaffConnect <no-reply@yourdomain.com>"
# APP_NAME="Lib-StaffConnect"
