# Vercel Frontend Environment Template
# Use these variables on your Vercel frontend project only.
#
# Proxies `/api/*` and `/uploads/*` to Render when VERCEL=1 (automatic on Vercel).
# Set at least one of BACKEND_URL or NEXT_PUBLIC_BACKEND_URL to your Render web URL (https, no trailing slash).
# Do not set DATABASE_URL on Vercel unless you intentionally run the API there.

NODE_ENV="production"

# Backend proxy target (Render web service URL — never a postgresql:// URL)
BACKEND_URL="https://your-service.onrender.com"

# Same value as BACKEND_URL so browsers load `/uploads/...` from Render (required for profile photos)
NEXT_PUBLIC_BACKEND_URL="https://your-service.onrender.com"

# Your Vercel site URL (no trailing slash preferred)
NEXTAUTH_URL="https://your-app.vercel.app"

# Must match the NEXTAUTH_SECRET on your Render backend
NEXTAUTH_SECRET="replace-with-long-random-string"

# Recommended on Vercel behind custom domains / preview URLs
NEXTAUTH_TRUST_HOST="true"

# Optional: forces proxy behaviour in non-Vercel environments (leave unset if unsure)
# FRONTEND_ONLY="true"
