# Vercel Frontend Environment Template
# Use these variables on your Vercel frontend project only.

NODE_ENV="production"

# Backend proxy target (MUST be Render backend web URL; never postgres URL)
BACKEND_URL="https://pgc-jobs-platform.onrender.com"

# Same as BACKEND_URL so profile images and uploads resolve in the browser (public)
NEXT_PUBLIC_BACKEND_URL="https://pgc-jobs-platform.onrender.com"

# Frontend URL
NEXTAUTH_URL="https://lib-staffconnect.vercel.app/"

# Keep aligned with backend auth secret when using shared auth tokens
NEXTAUTH_SECRET="eBeGoApw9Fo76w4MM7HBa7m0bFV/UgRwTNzXSPFYXJI="

# Optional
NEXTAUTH_TRUST_HOST="true"
