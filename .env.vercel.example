# Vercel Frontend Environment Template
# Use these variables on your Vercel frontend project only.

NODE_ENV="production"

# Backend proxy target (MUST be Render backend web URL; never postgres URL)
BACKEND_URL="https://your-backend.onrender.com"

# Frontend URL
NEXTAUTH_URL="https://your-frontend.vercel.app"

# Keep aligned with backend auth secret when using shared auth tokens
NEXTAUTH_SECRET="same-secret-as-render-backend"

# Optional
NEXTAUTH_TRUST_HOST="true"
